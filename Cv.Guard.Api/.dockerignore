# Ignore the bin and obj folders
bin/
obj/

# Ignore the user secrets folder
.secrets/

# Ignore files generated by Visual Studio
.vs/
.vscode/

# Ignore the Dockerfile and .dockerignore file itself
Dockerfile
.dockerignore

# Ignore the .user and .suo files used by Visual Studio
*.user
*.suo

# Ignore any local development and configuration files
appsettings.Development.json
appsettings.Local.json

# Ignore the publish directory
publish/

# Ignore the .NET Core SDK and Runtime Docker images
mcr.microsoft.com/dotnet/aspnet
mcr.microsoft.com/dotnet/sdk

# Ignore temporary files and logs
*.log
*.bak
*.swp

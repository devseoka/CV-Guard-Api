# Root is true to indicate that this is the root .editorconfig file
root = true

# General settings for all files
[*]
# Set the line length to 120 characters
max_line_length = 120

# Ensure that files end with a new line
insert_final_newline = true

# Remove trailing whitespace on save
trim_trailing_whitespace = true

# Use tabs for indentation
indent_style = tab

# Set the tab width to 4 spaces (or adjust as needed)
tab_width = 4

# Ensure that line endings are set to LF (Unix-style)
end_of_line = lf

# Settings for C# files
[*.cs]
# Set maximum line length to 120 characters for C# files
max_line_length = 120

# Use tabs for indentation in C# files
indent_style = tab

# Set the tab width to 4 spaces for C# files
tab_width = 4

# Ensure curly braces are on the same line for method declarations, properties, and control statements
csharp_brace_style = next_line

# Format method declarations with parentheses and return type on the same line
csharp_method_brace_style = next_line

# Ensure that newlines are added after method and property declarations
csharp_new_line_before_members = true

# Define the naming convention for C# files
dotnet_naming_rules.interface_prefix = I  # Prefix interfaces with "I"
dotnet_naming_rules.enum_case.style = E_Prefix  # Enums must start with "E"
dotnet_naming_rules.enum_case.symbols = enum_symbols
dotnet_naming_rules.enum_case.severity = error

# Enforce the use of var where type is apparent
dotnet_style_var_for_built_in_types = true

# Prefer camelCase for private fields
dotnet_style_private_fields = camel_case

# Use implicit type inference where possible
csharp_style_var_for_built_in_types = true
csharp_style_var_when_type_is_apparent = true

# Add a newline between class declarations and members
csharp_new_line_between_class_declarations_and_members = true

# Prefer explicit `readonly` for fields that are never reassigned
dotnet_style_readonly_fields = explicit

# Code style preferences
csharp_style_allow_all_members = true
csharp_style_indentation = true

# Space after commas
csharp_space_after_comma = true

# Require spaces around operators
csharp_space_around_operators = true

# Enforce consistent formatting of braces and indentation
csharp_brace_style = next_line

# Enable formatting for lambda expressions in method calls
csharp_style_lambda_expression = inline

# Ensure lambdas have a space after the `=>`
csharp_space_after_lambda_arrow = true

# Ensure lambda expressions use the `inline` style (without extra line breaks)
csharp_style_lambda_expression = inline

# Naming rule for constants to be in ALL_CAPS
dotnet_naming_rule.constant_case.style = CONSTANT_ALL_CAPS
dotnet_naming_rule.constant_case.symbols = constant_symbols
dotnet_naming_rule.constant_case.severity = error

# Define the symbols that the rule applies to
dotnet_naming_symbols.constant_symbols.applicable_kinds = field
dotnet_naming_symbols.constant_symbols.applicable_accessibilities = *
dotnet_naming_symbols.constant_symbols.required_modifiers = readonly

# Define the ALL_CAPS naming style for constants
dotnet_naming_style.CONSTANT_ALL_CAPS.capitalization = all_upper
dotnet_naming_style.CONSTANT_ALL_CAPS.required_prefix = 
dotnet_naming_style.CONSTANT_ALL_CAPS.required_suffix = 

# Define the naming rule for readonly fields to follow camelCase
dotnet_naming_rule.readonly_field_case.style = camelCase
dotnet_naming_rule.readonly_field_case.symbols = readonly_field_symbols
dotnet_naming_rule.readonly_field_case.severity = error

# Define the symbols that the rule applies to for readonly fields
dotnet_naming_symbols.readonly_field_symbols.applicable_kinds = field
dotnet_naming_symbols.readonly_field_symbols.applicable_accessibilities = private
dotnet_naming_symbols.readonly_field_symbols.required_modifiers = readonly

# Define the camelCase naming style for readonly fields
dotnet_naming_style.camelCase.capitalization = camel_case
dotnet_naming_style.camelCase.required_prefix = _
dotnet_naming_style.camelCase.required_suffix = 
